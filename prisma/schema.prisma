/**
 * Smart Shop - Prisma Schema
 * Complete data model for the shopping assistant SaaS application.
 * Using SQLite for this deployment (production would use PostgreSQL).
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/** User model - manages accounts, plans, and billing */
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  passwordHash   String?
  plan           String   @default("free") // "free" | "premium" | "family"
  budgetDefault  Int      @default(10000) // in cents
  avatarUrl      String?
  stripeCustomerId  String? @unique
  stripeSubscriptionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shoppingLists    ShoppingList[]
  shoppingSessions ShoppingSession[]
  authSessions     AuthSession[]
  subscriptions    Subscription[]
}

/** Subscription - Stripe subscription management */
model Subscription {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeId          String   @unique
  status            String   // "active", "past_due", "canceled", "trialing", "incomplete"
  plan              String   // "free", "premium", "family"
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  cancelAt          DateTime?
  canceledAt        DateTime?
  trialEnd          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([stripeId])
  @@index([status])
}

/** Auth Session - server-side session token storage */
model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

/** Shopping List - user's planned items before going to store */
model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Ma liste de courses")
  itemsJson String   @default("[]") // JSON array of {name, category, checked, quantity}
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/** Shopping Session - an active or completed shopping trip */
model ShoppingSession {
  id          String    @id @default(cuid())
  userId      String
  listId      String?
  budgetLimit Int       @default(10000) // in cents
  totalSpent  Float     @default(0)
  status      String    @default("active") // "active" | "completed" | "abandoned"
  location    String?
  startTime   DateTime  @default(now())
  endTime     DateTime?
  notes       String?

  scannedItems ScannedItem[]
  receipts     Receipt[]
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/** Scanned Item - each product scanned during a session */
model ScannedItem {
  id          String   @id @default(cuid())
  sessionId   String
  barcode     String
  productName String
  price       Int      // in cents
  category    String   @default("Autre")
  quantity    Int      @default(1)
  imageUrl    String?
  scannedAt   DateTime @default(now())

  session ShoppingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([barcode])
}

/** Receipt - generated ticket after session completion */
model Receipt {
  id        String   @id @default(cuid())
  sessionId String   @unique
  pdfData   String?  // Base64 encoded PDF
  csvData   String?  // CSV content
  hash      String   @unique // SHA-256 hash of receipt content
  totalAmount Float  @default(0) // computed/display field
  createdAt DateTime @default(now())

  session ShoppingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

/** Admin User - back-office access */
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("admin") // "superadmin" | "admin" | "support"
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/** Product Database - barcode → product info */
model Product {
  id          String   @id @default(cuid())
  barcode     String   @unique
  name        String
  price       Int      // in cents
  category    String   @default("Autre")
  imageUrl    String?
  brand       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Promo Code - discount codes for subscriptions */
model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float    @default(0)     // percentage (0-100)
  plan        String   @default("premium") // target plan
  maxUses     Int      @default(-1)    // -1 = unlimited
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

/** App Configuration - system-wide settings */
model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/** App Log - error/action logging */
model AppLog {
  id        String   @id @default(cuid())
  level     String   @default("info") // "info" | "warn" | "error"
  message   String
  context   String?  // JSON string with extra context
  userId    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}
